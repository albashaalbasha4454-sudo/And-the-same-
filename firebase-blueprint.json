{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users (admins and cashiers)",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "passwordHash": { "type": "string" },
        "salt": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "cashier"] }
      },
      "required": ["username", "passwordHash", "salt", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory items and services",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["product", "service"] },
        "author": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "salePrice": { "type": "number" },
        "costPrice": { "type": "number" },
        "allocated": { "type": "number" }
      },
      "required": ["name", "type", "quantity", "price"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer profiles",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "email": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["name", "phone"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Inventory suppliers",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["name"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Sales, shipping orders, and reservations",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "paidDate": { "type": "string", "format": "date-time" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "totalProfit": { "type": "number" },
        "totalCost": { "type": "number" },
        "type": { "type": "string", "enum": ["sale", "return", "shipping", "reservation"] },
        "customerInfo": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled", "shipped"] },
        "paymentStatus": { "type": "string", "enum": ["paid", "unpaid", "partial"] },
        "source": { "type": "string" },
        "shippingFee": { "type": "number" },
        "processedBy": { "type": "string" }
      },
      "required": ["date", "items", "total", "type", "status", "paymentStatus"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expenses",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "accountId": { "type": "string" }
      },
      "required": ["date", "description", "amount", "accountId"]
    },
    "FinancialAccount": {
      "title": "Financial Account",
      "description": "Cash tills or bank accounts",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["cash", "bank", "other"] },
        "userId": { "type": "string" }
      },
      "required": ["name", "type"]
    },
    "FinancialTransaction": {
      "title": "Financial Transaction",
      "description": "Money movements between accounts or outcomes",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string" },
        "fromAccountId": { "type": "string" },
        "toAccountId": { "type": "string" },
        "relatedInvoiceId": { "type": "string" },
        "relatedPurchaseId": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["date", "description", "amount", "type"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Immutable log of all actions",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "entityId": { "type": "string" },
        "entityType": { "type": "string" },
        "ip": { "type": "string" },
        "checksum": { "type": "string" }
      },
      "required": ["timestamp", "userId", "action", "details"]
    },
    "RecycleBinItem": {
      "title": "Recycle Bin Item",
      "description": "Soft-deleted entities",
      "type": "object",
      "properties": {
        "deletedAt": { "type": "string", "format": "date-time" },
        "deletedBy": { "type": "string" },
        "originalCollection": { "type": "string" },
        "originalId": { "type": "string" },
        "data": { "type": "object" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["deletedAt", "deletedBy", "originalCollection", "originalId", "data", "expiresAt"]
    },
    "BackupMetadata": {
      "title": "Backup Metadata",
      "description": "Records of backups performed",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["full", "incremental", "snapshot"] },
        "performedBy": { "type": "string" },
        "fileSize": { "type": "number" },
        "checksum": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "failed"] },
        "storagePath": { "type": "string" }
      },
      "required": ["timestamp", "type", "performedBy", "status"]
    },
    "ResetRequest": {
        "title": "Reset Request",
        "description": "High-risk system reset authorization",
        "type": "object",
        "properties": {
            "requestedAt": { "type": "string", "format": "date-time" },
            "requestedBy": { "type": "string" },
            "approvals": { "type": "array" },
            "scheduledAt": { "type": "string", "format": "date-time" },
            "status": { "type": "string", "enum": ["pending", "approved", "completed", "cancelled"] }
        },
        "required": ["requestedAt", "requestedBy", "approvals", "scheduledAt", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and credentials"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory products"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer list"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Supplier list"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Sales and orders"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Business expenses"
    },
    "/accounts/{accountId}": {
      "schema": "FinancialAccount",
      "description": "Financial accounts"
    },
    "/transactions/{transactionId}": {
      "schema": "FinancialTransaction",
      "description": "Financial transaction history"
    },
    "/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "System-wide action logs"
    },
    "/recycleBin/{itemId}": {
      "schema": "RecycleBinItem",
      "description": "Temporarily deleted data"
    },
    "/backups/{backupId}": {
      "schema": "BackupMetadata",
      "description": "Backup logs"
    },
    "/resetRequests/{requestId}": {
        "schema": "ResetRequest",
        "description": "System reset authorization chain"
    }
  }
}
